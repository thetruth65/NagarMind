# ═══════════════════════════════════════════
# NAGARMIND — Environment Configuration
# Copy to .env and fill all values
# See docs/SETUP_GUIDE.md for instructions
# ═══════════════════════════════════════════

# ─── APP ────────────────────────────────────
APP_NAME=NagarMind
APP_ENV=development
DEBUG=true
SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ─── NEON POSTGRESQL ────────────────────────
# Get free at: https://neon.tech
DATABASE_URL=
DATABASE_URL_SYNC=

# ─── GEMINI API KEYS (4 keys for rotation) ──
# Get free at: https://aistudio.google.com
# Each key: 15 RPM, 1500 RPD on gemini-1.5-flash
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_MODEL=gemini-2.5-flash-lite

# ─── SARVAM AI KEYS (4 keys for rotation) ───
# Get free at: https://dashboard.sarvam.ai
# Each key: 1000 INR free credits
SARVAM_API_KEY_1=
SARVAM_API_KEY_2=
SARVAM_API_KEY_3=
SARVAM_API_KEY_4=

# ─── CLOUDFLARE R2 ──────────────────────────
# Get free at: https://dash.cloudflare.com → R2
CF_R2_ACCOUNT_ID=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_R2_BUCKET_NAME=
CF_R2_PUBLIC_URL=

# ─── SMS (Fast2SMS — India free credits) ────
# Get free at: https://www.fast2sms.com (free ₹50 credits on signup)
FAST2SMS_API_KEY=

# ─── GOOGLE MAPS ────────────────────────────
# Get at: https://console.cloud.google.com
# Enable: Maps JavaScript API, Geocoding API
GOOGLE_MAPS_API_KEY=

# ─── CORS ───────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── OTP CONFIG ─────────────────────────────
OTP_LENGTH=6
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=3
OTP_RESEND_COOLDOWN_SECONDS=60